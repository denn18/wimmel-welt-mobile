{
  "expo": {
    "name": "Wimmel Welt",
    "slug": "wimmel-welt-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/wimmel-welt-icon.png",
    "scheme": "com.denniescharton.wimmelweltmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.denniescharton.wimmelweltmobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {},
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.denniescharton.wimmelweltmobile"
    },
    "splash": {
           "image": "./assets/images/ww-Transparent.svg",
      "resizeMode": "contain",
      "backgroundColor": "#EEF2FF"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/wimmel-welt-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#EEF2FF",
          "dark": {
            "backgroundColor": "#EEF2FF"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "root": "pages"
      },
      "eas": {
        "projectId": "a54d9025-853e-4ee5-acbc-a70b9dd95799"
      }
    }
  }
}
