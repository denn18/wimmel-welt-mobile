{
  "expo": {
    "name": "Wimmel Welt",
    "slug": "wimmel-welt-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./app/assets/images/wimmel-welt-icon.png",
    "scheme": "wimmelwelt",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.denniescharton.wimmelweltmobile"
    },
    "android": {
      "package": "com.denniescharton.wimmelweltmobile",
      "adaptiveIcon": {
        "backgroundColor": "#EEF2FF",
        "foregroundImage": "./app/assets/images/icon.png",
        "backgroundImage": "./app/assets/images/android-icon-background.png",
        "monochromeImage": "./app/assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "splash": {
      "image": "./app/assets/images/wimmel-welt-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EEF2FF"
    },
    "web": {
      "output": "static",
      "favicon": "./app/assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "root": "app/pages"
      },
      "eas": {
        "projectId": "a54d9025-853e-4ee5-acbc-a70b9dd95799"
      }
    }
  }
}
